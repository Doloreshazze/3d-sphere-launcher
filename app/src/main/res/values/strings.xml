    <!-- Onboarding Tour Strings -->
    <string name="ob_title_permission">App Access</string>
    <string name="ob_desc_permission">The launcher requires your consent to query installed applications (QUERY_ALL_PACKAGES). This is used strictly locally on your device to display and launch applications in the 3D Sphere and 2D grid. We guarantee 100% privacy.</string>
    <string name="ob_title_sphere">3D App Sphere</string>
    <string name="ob_desc_sphere">Welcome! Your applications float in three-dimensional space. Rotate the sphere in any direction with swipes and launch them with a single tap.</string>
    <string name="ob_title_access">Quick Access</string>
    <string name="ob_desc_access">Freeze sphere rotation with the padlock button or control inertia in the bottom-left corner. Launch the Camera instantly with one tap in the bottom-right corner!</string>
    <string name="ob_title_music">Music Beat</string>
    <string name="ob_desc_music">Enable \'Audio Reactivity\' in settings: the sphere and neon nebula will dynamically swell and flash in sync with your YouTube music or your voice.</string>
