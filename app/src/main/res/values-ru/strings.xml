    <!-- Onboarding Tour Strings -->
    <string name="ob_title_permission">Доступ к приложениям</string>
    <string name="ob_desc_permission">Лаунчеру требуется ваше согласие для получения списка установленных приложений (QUERY_ALL_PACKAGES). Это используется строго локально на вашем устройстве для отображения и запуска приложений в 3D-сфере. Мы гарантируем 100% конфиденциальность.</string>
    <string name="ob_title_sphere">3D Сфера приложений</string>
    <string name="ob_desc_sphere">Добро пожаловать! Ваши приложения парят в трехмерном пространстве. Вращайте сферу в любом направлении свайпами и запускайте их одним касанием.</string>
    <string name="ob_title_access">Быстрый доступ</string>
    <string name="ob_desc_access">Заморозьте вращение сферы кнопкой-замком или управляйте инерцией в левом нижнем углу. Быстрый запуск камеры — одним касанием в правом нижнем углу!</string>
    <string name="ob_title_music">Музыкальный ритм</string>
    <string name="ob_desc_music">Включите \'Аудио-реактивность\' в настройках: сфера и неоновая туманность будут динамично расширяться и пульсировать в такт вашей музыке из YouTube или вашему голосу.</string>
    <string name="ob_btn_agree">Согласен</string>
    <string name="ob_btn_next">Далее</string>
    <string name="ob_btn_start">Старт</string>
    <string name="ob_btn_skip">Пропустить</string>
    <string name="ob_title_gestures">Воздушные жесты</string>
    <string name="ob_desc_gestures">Управляйте сферой с помощью руки, не касаясь экрана! Схемы жестов: захват щепоткой, масштаб щепоткой, масштаб открытой ладонью, запуск щепоткой. Включите это в настройках.</string>
    <string name="ob_btn_back">Назад</string>

