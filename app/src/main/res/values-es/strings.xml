    <!-- Onboarding Tour Strings -->
    <string name="ob_title_permission">Acceso a aplicaciones</string>
    <string name="ob_desc_permission">El launcher requiere su consentimiento para consultar las aplicaciones instaladas (QUERY_ALL_PACKAGES). Esto se usa estrictamente a nivel local en su dispositivo para mostrar e iniciar aplicaciones en la Esfera 3D. Garantizamos 100% de privacidad.</string>
    <string name="ob_title_sphere">Esfera de aplicaciones 3D</string>
    <string name="ob_desc_sphere">¡Bienvenido! Sus aplicaciones flotan en un espacio tridimensional. Rote la esfera en cualquier dirección deslizando y ábralas con un solo toque.</string>
    <string name="ob_title_access">Acceso rápido</string>
    <string name="ob_desc_access">Congele la rotación de la esfera con el botón del candado o controle la inercia en la esquina inferior izquierda. ¡Inicie la cámara al instante con un toque en la esquina inferior derecha!</string>
    <string name="ob_title_music">Ritmo de música</string>
    <string name="ob_desc_music">Active la \'Reactividad de audio\' en la configuración: la esfera y la nebulosa de neón se expandirán y pulsarán dinámicamente en sincronía con su música o su voz.</string>
    <string name="ob_btn_agree">Aceptar</string>
    <string name="ob_btn_next">Siguiente</string>
    <string name="ob_btn_start">Empezar</string>
    <string name="ob_btn_skip">Omitir</string>
    <string name="ob_title_gestures">Gestos aéreos</string>
    <string name="ob_desc_gestures">¡Controle la esfera con su mano sin tocar la pantalla! Opciones: pellizcar, acercar pellizcando, acercar con la palma abierta, iniciar pellizcando. Actívelo en la configuración.</string>
    <string name="ob_btn_back">Atrás</string>

