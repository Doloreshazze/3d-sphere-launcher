    <!-- Onboarding Tour Strings -->
    <string name="ob_title_permission">App-Zugriff</string>
    <string name="ob_desc_permission">Der Launcher benötigt Ihre Zustimmung, um installierte Apps abzufragen (QUERY_ALL_PACKAGES). Dies wird nur lokal auf Ihrem Gerät verwendet, um Apps in der 3D-Sphäre anzuzeigen und zu starten. Wir garantieren 100% Datenschutz.</string>
    <string name="ob_title_sphere">3D-App-Sphäre</string>
    <string name="ob_desc_sphere">Willkommen! Ihre Apps schweben im dreidimensionalen Raum. Drehen Sie die Sphäre in jede Richtung mit Wischgesten und starten Sie Apps mit einem Fingertipp.</string>
    <string name="ob_title_access">Schnellzugriff</string>
    <string name="ob_desc_access">Stoppen Sie die Rotation der Sphäre mit der Schloss-Taste oder steuern Sie die Trägheit unten links. Starten Sie die Kamera sofort mit einem Tippen unten rechts!</string>
    <string name="ob_title_music">Musik-Rhythmus</string>
    <string name="ob_desc_music">Aktivieren Sie die \'Audio-Reaktivität\' in den Einstellungen: Die Sphäre und der Neon-Nebel erweitern und pulsieren dynamisch synchron mit Ihrer Musik oder Stimme.</string>
    <string name="ob_btn_agree">Zustimmen</string>
    <string name="ob_btn_next">Weiter</string>
    <string name="ob_btn_start">Starten</string>
    <string name="ob_btn_skip">Überspringen</string>
    <string name="ob_title_gestures">Luftgesten</string>
    <string name="ob_desc_gestures">Steuern Sie die Sphäre mit der Hand, ohne den Bildschirm zu berühren! Gesten: Greifen zum Auswählen, Greifen zum Vergrößern/Verkleinern. In den Einstellungen aktivieren.</string>
    <string name="ob_btn_back">Zurück</string>

