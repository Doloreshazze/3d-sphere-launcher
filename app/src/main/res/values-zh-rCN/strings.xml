    <!-- Onboarding Tour Strings -->
    <string name="ob_title_permission">应用访问</string>
    <string name="ob_desc_permission">启动器需要您的同意以查询已安装的应用 (QUERY_ALL_PACKAGES)。这仅在您的设备上本地使用，以便在 3D 球体中显示和启动应用。我们保证 100% 的隐私。</string>
    <string name="ob_title_sphere">3D 应用球体</string>
    <string name="ob_desc_sphere">欢迎！您的应用程序漂浮在三维空间中。通过滑动以任何方向旋转球体，并单击启动它们。</string>
    <string name="ob_title_access">快速访问</string>
    <string name="ob_desc_access">使用锁形按钮冻结球体旋转，或控制左下角的惯性。点击右下角即可立即启动相机！</string>
    <string name="ob_title_music">音乐节拍</string>
    <string name="ob_desc_music">在设置中启用“音频响应”：球体和霓虹星云将随着您的音乐或声音动态膨胀并闪烁。</string>
    <string name="ob_btn_agree">同意</string>
    <string name="ob_btn_next">下一步</string>
    <string name="ob_btn_start">开始</string>
    <string name="ob_btn_skip">跳过</string>
    <string name="ob_title_gestures">隔空手势</string>
    <string name="ob_desc_gestures">无需触摸屏幕，即可用手控制球体！手势方案：捏合、通过捏合缩放、通过张开手掌缩放、通过捏合启动。在设置中启用。</string>
    <string name="ob_btn_back">返回</string>

